# Copy this file to .env and fill in real values. DO NOT commit your real .env to source control.

# Optional: Gemini API key (if used by tooling)
GEMINI_API_KEY=""

# APP_URL: Public URL where the app is hosted (optional)
APP_URL=""

# -----------------------------
# Supabase (client - exposed to Vite via VITE_ prefix)
# -----------------------------
# Public (anon) key and URL are used by client-side code. These are safe to be VITE_ vars.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# -----------------------------
# Supabase (server - keep secret)
# -----------------------------
# This service role key must remain private and is used by the server-side API (api/supabaseClient.ts)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: API base (if you host the API on a different origin)
VITE_API_BASE=

# Admin credentials (optional - override defaults in api/dataStore.ts)
VITE_ADMIN_EMAIL=admin@nairobi.local
VITE_ADMIN_PASSWORD=admin2030

# SMTP (for password resets / emails)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@nairobiwater.co.ke

# Local preview server port
PORT=4173

# Notes:
# - After copying to `.env` you can run the preview server with the environment loaded:
#     node -r dotenv/config preview-server.js
#   or add `import 'dotenv/config';` near the top of `preview-server.js`.
# - Keep `SUPABASE_SERVICE_ROLE_KEY` secret; do not expose it to client-side code.
